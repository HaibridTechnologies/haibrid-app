{
  "name": "@links-app/app",
  "version": "1.0.0",
  "private": true,
  "main": "server.js",
  "scripts": {
    "kill-port": "lsof -ti :3000 | xargs kill -9 2>/dev/null || true",
    "server": "npm run kill-port && node --watch server.js",
    "client": "vite",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "vite build",
    "start": "npm run kill-port && node server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "@llamaindex/liteparse": "^1.5.3",
    "async-mutex": "^0.5.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "helmet": "^8.2.0",
    "langsmith": "^0.5.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.0",
    "vite": "^5.4.10",
    "vitest": "^4.1.9"
  }
}
