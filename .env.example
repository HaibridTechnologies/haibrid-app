# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key — used for content summarisation, evaluation, and chat.
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Optional: LangSmith tracing ───────────────────────────────────────────────
# Remove or leave blank to disable request tracing.
# Sign up at https://smith.langchain.com/
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=haibrid-app
